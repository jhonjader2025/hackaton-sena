# Movilidata OS — Environment Variables
# Copy this file to .env and fill in your values.
# DATABASE_URL defaults to sqlite:///./movilidata.db
DATABASE_URL=sqlite:///./movilidata.db
# CORS origins (comma-separated)
CORS_ORIGINS=http://localhost:3000
# Allowed hosts for TrustedHostMiddleware (comma-separated)
ALLOWED_HOSTS=localhost,127.0.0.1
# Scheduler interval in minutes (default: 5)
SCHEDULER_INTERVAL_MINUTES=5
# LLM API keys (optional — uses fallback if neither is set)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
